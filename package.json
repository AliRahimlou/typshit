{
  "name": "typsh-it-shopify-agent-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "bash ./scripts/run-agent-server.sh watch",
    "site:dev": "bash ./scripts/dev-full-site.sh",
    "start": "bash ./scripts/dev-full-site.sh",
    "server:start": "bash ./scripts/run-agent-server.sh",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "hooks:install": "bash ./scripts/install-git-hooks.sh",
    "store:sync-data": "bash ./scripts/sync-store-data.sh",
    "theme:auth": "bash ./scripts/auth-shopify.sh",
    "theme:list": "bash ./scripts/list-themes.sh",
    "theme:push": "bash ./scripts/push-theme.sh",
    "theme:preview": "bash ./scripts/preview-theme.sh",
    "store:deploy": "bash ./scripts/deploy-store.sh"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@shopify/cli": "^3.93.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
