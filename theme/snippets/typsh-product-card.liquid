{% liquid
  assign product = all_products[product_handle]
  assign card_summary = summary
  if product != blank and card_summary == blank
    assign card_summary = product.description | strip_html | truncatewords: 18
  endif

  assign product_price = blank
  assign compare_at_price = blank
  if product != blank and product.selected_or_first_available_variant != blank
    assign product_price = product.selected_or_first_available_variant.price
    assign compare_at_price = product.selected_or_first_available_variant.compare_at_price
  endif
%}

<article class="typsh-card typsh-product-card {{ card_class }}">
  <div class="typsh-card-topline">
    {% if badge != blank %}
      <span class="typsh-badge">{{ badge }}</span>
    {% endif %}
    {% if product != blank and product.type != blank %}
      <p class="typsh-caption">{{ product.type }}</p>
    {% endif %}
  </div>

  {% if product != blank and product.featured_media != blank %}
    <a class="typsh-media-frame typsh-media-frame--portrait" href="{{ product.url }}">
      {{ product.featured_media.preview_image | image_url: width: 960 | image_tag: widths: '320, 480, 640, 960', sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw', loading: 'lazy', class: 'typsh-product-card__image', alt: product.featured_media.alt | default: product.title }}
    </a>
  {% else %}
    <div class="typsh-media-frame typsh-media-frame--portrait">
      <div class="typsh-placeholder">Product</div>
    </div>
  {% endif %}

  <div class="typsh-grid">
    <div class="typsh-grid" style="gap: 10px;">
      <h3 class="typsh-card-title">{% if product != blank %}{{ product.title }}{% else %}Coming soon{% endif %}</h3>
      {% if card_summary != blank %}
        <p class="typsh-card-copy">{{ card_summary }}</p>
      {% endif %}
    </div>

    {% if product_price != blank %}
      <p class="typsh-price">
        <span>{{ product_price | money }}</span>
        {% if compare_at_price != blank and compare_at_price > product_price %}
          <s>{{ compare_at_price | money }}</s>
        {% endif %}
      </p>
    {% endif %}
  </div>

  <div>
    {% if product != blank %}
      <a class="typsh-button typsh-button--secondary" href="{{ product.url }}">{{ cta_label | default: 'Shop now' }}</a>
    {% else %}
      <span class="typsh-button typsh-button--secondary">{{ cta_label | default: 'Shop now' }}</span>
    {% endif %}
  </div>
</article>