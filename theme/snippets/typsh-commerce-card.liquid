{% liquid
  assign card_product = product_object
  if card_product == blank and product_handle != blank
    assign card_product = all_products[product_handle]
  endif

  assign card_title = heading
  if card_title == blank and card_product != blank
    assign card_title = card_product.title
  endif

  assign card_copy = copy
  if card_copy == blank and card_product != blank
    assign card_copy = card_product.description | strip_html | truncatewords: 18
  endif

  assign card_variant = blank
  if card_product != blank
    assign card_variant = card_product.selected_or_first_available_variant
  endif

  assign card_badge = badge
  if card_badge == blank and card_variant != blank and card_variant.compare_at_price > card_variant.price
    assign savings_amount = card_variant.compare_at_price | minus: card_variant.price | money_without_trailing_zeros
    assign card_badge = 'Save ' | append: savings_amount
  endif

  assign card_url = url
  if card_url == blank and card_product != blank
    assign card_url = card_product.url
  endif
%}

<article class="typsh-commerce-card {{ class }}" data-typsh-product-card>
  {% if card_product != blank and card_product.featured_media != blank %}
    <a class="typsh-commerce-card__media" href="{{ card_url }}">
      {{ card_product.featured_media.preview_image | image_url: width: 960 | image_tag: widths: '320, 480, 640, 960', sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw', loading: 'lazy', alt: card_product.featured_media.alt | default: card_title }}
    </a>
  {% else %}
    <a class="typsh-commerce-card__media" href="{{ card_url }}">
      <div class="typsh-commerce-empty" style="display:grid;place-items:center;height:100%;">Product</div>
    </a>
  {% endif %}

  <div class="typsh-commerce-grid" style="gap: 12px;">
    <div class="typsh-commerce-card__row">
      {% if card_badge != blank %}
        <span class="typsh-commerce-card__badge">{{ card_badge }}</span>
      {% endif %}
      {% if card_product != blank and card_product.type != blank %}
        <p class="typsh-commerce-meta-text">{{ card_product.type }}</p>
      {% endif %}
    </div>

    <div class="typsh-commerce-grid" style="gap: 8px;">
      <h3 class="typsh-commerce-card__title">{{ card_title | default: 'Coming soon' }}</h3>
      {% if card_copy != blank %}
        <p class="typsh-commerce-card__copy">{{ card_copy }}</p>
      {% endif %}
    </div>

    {% if card_variant != blank %}
      <div class="typsh-commerce-card__price">
        <strong>{{ card_variant.price | money }}</strong>
        {% if card_variant.compare_at_price > card_variant.price %}
          <s>{{ card_variant.compare_at_price | money }}</s>
        {% endif %}
      </div>
    {% endif %}
  </div>

  <div class="typsh-commerce-card__actions">
    {% if show_quick_add != false and card_variant != blank %}
      <form method="post" action="/cart/add" data-typsh-ajax-cart-form>
        <input type="hidden" name="id" value="{{ card_variant.id }}" data-typsh-variant-id>
        <button class="typsh-commerce-quick-add" type="submit" {% unless card_variant.available %}disabled{% endunless %}>
          {% if card_variant.available %}{{ quick_add_label | default: 'Quick add' }}{% else %}Sold out{% endif %}
        </button>
      </form>
      <p class="typsh-commerce-quick-add-status" data-quick-add-status></p>
    {% endif %}

    <a class="typsh-commerce-link-button" href="{{ card_url }}">{{ cta_label | default: 'View product' }}</a>
  </div>
</article>