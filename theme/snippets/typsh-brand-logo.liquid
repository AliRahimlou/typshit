{% liquid
  assign logo_width = width | default: 220
  assign logo_alt = alt | default: shop.name
  assign logo_class = class | default: ''
  assign animated = animated
  if animated == nil
    assign animated = true
  endif

  if animated
    assign logo_asset = 'typsh-it-color-cycle-wordmark.svg'
  else
    assign logo_asset = 'typsh-it-wordmark.svg'
  endif
%}

<img
  src="{{ logo_asset | asset_url }}"
  alt="{{ logo_alt | escape }}"
  class="{{ logo_class }}"
  width="{{ logo_width }}"
  loading="eager"
  style="display:block;height:auto;max-width:100%;"
>