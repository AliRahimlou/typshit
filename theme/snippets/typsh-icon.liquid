{% liquid
  assign icon_name = icon | default: 'spark'
  assign icon_class = class | default: ''
%}

{% case icon_name %}
  {% when 'truck' %}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M3.5 6.5h11v8.5h-11z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
      <path d="M14.5 9.5h3.4l2.6 2.8v2.7h-6z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
      <circle cx="8" cy="17.5" r="1.9" stroke="currentColor" stroke-width="1.7"/>
      <circle cx="18" cy="17.5" r="1.9" stroke="currentColor" stroke-width="1.7"/>
    </svg>
  {% when 'shield' %}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 3.5 5.5 6v5.6c0 4.2 2.7 7.9 6.5 9 3.8-1.1 6.5-4.8 6.5-9V6z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
      <path d="m9.3 12 1.8 1.8 3.7-4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  {% when 'message' %}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M5 6.5h14v9H9.2L5 18.7z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
      <path d="M8.5 10.2h7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
      <path d="M8.5 13.4h4.6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
    </svg>
  {% else %}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 2.9 14.3 9l6.1 2.3-6.1 2.3-2.3 6.1-2.3-6.1-6.1-2.3L9.7 9z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
    </svg>
{% endcase %}