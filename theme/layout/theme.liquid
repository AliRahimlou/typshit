<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- else -%}
      <link
        rel="icon"
        type="image/svg+xml"
        href="{{ 'typsh-horizon-header-logo.svg' | asset_url }}"
      >
    {%- endif -%}

    {% # theme-check-disable RemoteAsset %}
    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    <script>
      (function () {
        const isLocalThemePreview =
          window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost';

        if (!isLocalThemePreview) {
          return;
        }

        const blockedCustomElements = new Set([
          'shopify-account',
          'shopify-store',
          'shopify-accelerated-checkout',
          'shopify-accelerated-checkout-cart',
        ]);
        const blockedUrlFragments = [
          'shop.app',
          '/accounts/pre_auth',
          '/pay/hop',
          '/checkouts/internal/preloads.js',
          'shopify.dynamic_checkout',
        ];
        const localOnlySelectors = [
          '.account-button',
          'shopify-store',
          'shopify-account',
          '.accelerated-checkout-block',
          '.additional-checkout-buttons',
          'shopify-accelerated-checkout',
          'shopify-accelerated-checkout-cart',
          'meta#shopify-digital-wallet',
          'meta[name="shopify-checkout-api-token"]',
          'meta#in-context-paypal-metadata',
          'script[src*="/checkouts/internal/preloads.js"]',
          'script[src*="shop.app/checkouts/internal/preloads.js"]',
          'script[data-source-attribution*="shopify.dynamic_checkout"]',
          'link#shopify-accelerated-checkout-styles',
          'style#shopify-accelerated-checkout-cart',
          'iframe[src*="shop.app"]',
          'iframe[src*="/accounts/pre_auth"]',
          'iframe[src*="/pay/hop"]',
        ];

        const shouldBlockUrl = (value) =>
          typeof value === 'string' && blockedUrlFragments.some((fragment) => value.includes(fragment));

        const removeLocalOnlyEmbeds = () => {
          document.querySelectorAll(localOnlySelectors.join(',')).forEach((node) => {
            const container = node.closest(
              '.account-button, .accelerated-checkout-block, .additional-checkout-buttons'
            );

            (container || node).remove();
          });
        };

        const style = document.createElement('style');
        style.textContent = [
          '.account-button,',
          '.accelerated-checkout-block,',
          '.additional-checkout-buttons,',
          'shopify-store,',
          'shopify-account,',
          'shopify-accelerated-checkout,',
          'shopify-accelerated-checkout-cart { display: none !important; }',
        ].join(' ');
        document.head.appendChild(style);

        const installBlockedSrcProperty = (ctor) => {
          const descriptor = Object.getOwnPropertyDescriptor(ctor.prototype, 'src');

          if (!descriptor || !descriptor.configurable || !descriptor.set || !descriptor.get) {
            return;
          }

          Object.defineProperty(ctor.prototype, 'src', {
            configurable: true,
            enumerable: descriptor.enumerable,
            get: descriptor.get,
            set(value) {
              if (shouldBlockUrl(value)) {
                return value;
              }

              return descriptor.set.call(this, value);
            },
          });
        };

        installBlockedSrcProperty(HTMLIFrameElement);
        installBlockedSrcProperty(HTMLScriptElement);

        const originalDefine = window.customElements.define.bind(window.customElements);
        window.customElements.define = function (name, constructor, options) {
          if (blockedCustomElements.has(name)) {
            return;
          }

          return originalDefine(name, constructor, options);
        };

        let shopifyState = window.Shopify || {};
        const normalizeShopify = (value) => {
          const shopify = value || {};

          if (!shopify.PaymentButton) {
            shopify.PaymentButton = {};
          }

          shopify.PaymentButton.init = removeLocalOnlyEmbeds;
          return shopify;
        };

        shopifyState = normalizeShopify(shopifyState);

        Object.defineProperty(window, 'Shopify', {
          configurable: true,
          get() {
            return shopifyState;
          },
          set(value) {
            shopifyState = normalizeShopify(value);
          },
        });

        const originalAppendChild = Node.prototype.appendChild;
        Node.prototype.appendChild = function (node) {
          if (
            (node instanceof HTMLIFrameElement || node instanceof HTMLScriptElement) &&
            shouldBlockUrl(node.src)
          ) {
            return node;
          }

          return originalAppendChild.call(this, node);
        };

        const originalInsertBefore = Node.prototype.insertBefore;
        Node.prototype.insertBefore = function (node, child) {
          if (
            (node instanceof HTMLIFrameElement || node instanceof HTMLScriptElement) &&
            shouldBlockUrl(node.src)
          ) {
            return node;
          }

          return originalInsertBefore.call(this, node, child);
        };

        const originalReplaceChild = Node.prototype.replaceChild;
        Node.prototype.replaceChild = function (node, child) {
          if (
            (node instanceof HTMLIFrameElement || node instanceof HTMLScriptElement) &&
            shouldBlockUrl(node.src)
          ) {
            return child;
          }

          return originalReplaceChild.call(this, node, child);
        };

        const originalAppend = Element.prototype.append;
        Element.prototype.append = function (...nodes) {
          const allowedNodes = nodes.filter(
            (node) =>
              !((node instanceof HTMLIFrameElement || node instanceof HTMLScriptElement) && shouldBlockUrl(node.src))
          );

          if (allowedNodes.length === 0) {
            return;
          }

          return originalAppend.apply(this, allowedNodes);
        };

        const originalPrepend = Element.prototype.prepend;
        Element.prototype.prepend = function (...nodes) {
          const allowedNodes = nodes.filter(
            (node) =>
              !((node instanceof HTMLIFrameElement || node instanceof HTMLScriptElement) && shouldBlockUrl(node.src))
          );

          if (allowedNodes.length === 0) {
            return;
          }

          return originalPrepend.apply(this, allowedNodes);
        };

        const originalSetAttribute = Element.prototype.setAttribute;
        Element.prototype.setAttribute = function (name, value) {
          if (
            (this instanceof HTMLIFrameElement || this instanceof HTMLScriptElement) &&
            name === 'src' &&
            shouldBlockUrl(value)
          ) {
            return;
          }

          return originalSetAttribute.call(this, name, value);
        };

        const originalFetch = window.fetch?.bind(window);
        if (originalFetch) {
          window.fetch = function (input, init) {
            const url = typeof input === 'string' ? input : input?.url;

            if (shouldBlockUrl(url)) {
              return Promise.resolve(new Response('', { status: 204, statusText: 'No Content' }));
            }

            return originalFetch(input, init);
          };
        }

        const originalXHROpen = XMLHttpRequest.prototype.open;
        XMLHttpRequest.prototype.open = function (method, url, ...rest) {
          this.__typshBlockedRequest = shouldBlockUrl(url);
          return originalXHROpen.call(this, method, url, ...rest);
        };

        const originalXHRSend = XMLHttpRequest.prototype.send;
        XMLHttpRequest.prototype.send = function (...args) {
          if (this.__typshBlockedRequest) {
            this.abort();
            return;
          }

          return originalXHRSend.apply(this, args);
        };

        const observer = new MutationObserver(removeLocalOnlyEmbeds);
        observer.observe(document.documentElement, { childList: true, subtree: true });

        removeLocalOnlyEmbeds();
        window.__TYPSH_LOCAL_THEME_PREVIEW__ = true;
      })();
    </script>

    {{ content_for_header }}
    {% # theme-check-enable RemoteAsset %}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script>
      // Inline header height and menu style calculations to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight(), updateTransparentHeaderOffset() and setHeaderMenuStyle() utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerTopRow = header.querySelector('.header__row--top');
        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        if (headerTopRow) {
          window.requestAnimationFrame(function () {
            document.body.style.setProperty('--top-row-height', `${headerTopRow.offsetHeight}px`);
          });
        }

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();

      (function setHeaderMenuStyle() {
        const headerComponent = document.querySelector('#header-component');
        if (headerComponent) {
          const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
          const overflowList = headerComponent?.querySelector('overflow-list');
          const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
          headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
        }
      })();
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    <footer>
      {% sections 'footer-group' %}
    </footer>

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
