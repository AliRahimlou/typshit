<section class="typsh-commerce-section typsh-product-faq-section">
  <div class="typsh-commerce-shell">
    <div class="typsh-commerce-panel" style="padding: clamp(22px, 3vw, 34px);">
      <div class="typsh-commerce-recommendations__header">
        <p class="typsh-commerce-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="typsh-commerce-heading">{{ section.settings.heading }}</h2>
        <p class="typsh-commerce-copy">{{ section.settings.body }}</p>
      </div>

      <div class="typsh-commerce-faq-grid">
        {% for block in section.blocks %}
          <details class="typsh-commerce-accordion" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
            <summary>
              <span class="typsh-commerce-card__title">{{ block.settings.question }}</span>
              <span class="typsh-commerce-accordion__icon">+</span>
            </summary>
            <div class="typsh-commerce-accordion__body rte">{{ block.settings.answer }}</div>
          </details>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "typsh Product FAQ",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Answer hesitation"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FAQs near the decision point"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "These answers should be practical, concise, and specific enough to reduce post-click hesitation on mobile."
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What problem does this solve?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Summarize the exact before-and-after value in plain language instead of defaulting to generic feature copy.</p>"
        }
      ]
    }
  ]
}
{% endschema %}