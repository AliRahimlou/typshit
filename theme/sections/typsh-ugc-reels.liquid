<section class="typsh-commerce-section typsh-ugc-reels-section">
  <div class="typsh-commerce-shell">
    <div class="typsh-commerce-panel typsh-commerce-reels">
      <div class="typsh-commerce-reels__header">
        <p class="typsh-commerce-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="typsh-commerce-heading">{{ section.settings.heading }}</h2>
        <p class="typsh-commerce-copy">{{ section.settings.body }}</p>
      </div>

      <div class="typsh-commerce-reels__track" role="list">
        {% for block in section.blocks %}
          {% liquid
            assign reel_product = blank
            assign reel_collection = blank
            assign reel_collection_image = blank
            assign reel_link = block.settings.link | default: ''

            if block.settings.product != blank
              assign reel_product = block.settings.product
              if reel_product.url == blank
                assign reel_product = all_products[block.settings.product]
              endif
            elsif reel_link contains '/products/'
              assign reel_product_handle = reel_link | split: '/products/' | last | split: '#' | first | split: '?' | first
              assign reel_product = all_products[reel_product_handle]
            elsif reel_link contains '/collections/'
              assign reel_collection_handle = reel_link | split: '/collections/' | last | split: '#' | first | split: '?' | first
              assign reel_collection = collections[reel_collection_handle]
              if reel_collection != blank
                if reel_collection.featured_image != blank
                  assign reel_collection_image = reel_collection.featured_image
                elsif reel_collection.products_count > 0
                  assign reel_product = reel_collection.products.first
                endif
              endif
            endif
          %}
          <article class="typsh-commerce-reel" role="listitem" {{ block.shopify_attributes }}>
            <div class="typsh-commerce-reel__media">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 900 | image_tag: widths: '320, 480, 640, 900', sizes: '280px', loading: 'lazy', alt: block.settings.title }}
              {% elsif reel_product != blank and reel_product.featured_media != blank %}
                {{ reel_product.featured_media.preview_image | image_url: width: 900 | image_tag: widths: '320, 480, 640, 900', sizes: '280px', loading: 'lazy', alt: reel_product.title }}
              {% elsif reel_collection_image != blank %}
                {{ reel_collection_image | image_url: width: 900 | image_tag: widths: '320, 480, 640, 900', sizes: '280px', loading: 'lazy', alt: reel_collection.title }}
              {% else %}
                <div class="typsh-commerce-empty typsh-commerce-empty--media">
                  <span class="typsh-commerce-empty__eyebrow">{{ block.settings.badge | default: 'Story' }}</span>
                  <span class="typsh-commerce-empty__title">{{ block.settings.title }}</span>
                </div>
              {% endif %}
            </div>
            <div class="typsh-commerce-grid" style="gap: 10px;">
              <div class="typsh-commerce-card__row">
                <span class="typsh-commerce-card__badge">{{ block.settings.badge }}</span>
                <span class="typsh-commerce-reel__author">{{ block.settings.author }}</span>
              </div>
              <h3 class="typsh-commerce-reel__title">{{ block.settings.title }}</h3>
              <p class="typsh-commerce-reel__meta">{{ block.settings.caption }}</p>
            </div>
            {% if block.settings.link != blank %}
              <a class="typsh-commerce-link-button" href="{{ block.settings.link }}">{{ block.settings.link_label }}</a>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "typsh UGC reels",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Community and creator proof"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See it like a social feed"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "This section is built to feel closer to short-form content than a static testimonial strip. Use vertical media, creator captions, and clear next actions."
    }
  ],
  "blocks": [
    {
      "type": "reel",
      "name": "Reel",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Fallback product"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge",
          "default": "UGC"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Creator handle"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Show the product in a real use case"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption",
          "default": "Use a before-and-after angle, contextual shot, or creator reaction rather than generic promotional copy."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Shop this look"
        }
      ]
    }
  ]
}
{% endschema %}