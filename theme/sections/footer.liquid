{{ 'typsh-shell.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign shop_links = 'Best Sellers|/collections/best-sellers,Problem Solvers|/collections/problem-solvers,New Arrivals|/collections/new-arrivals' | split: ','
  assign help_links = 'Track Order|/pages/track-order,FAQ|/pages/faq,Contact|/pages/contact' | split: ','
  assign legal_links = 'About|/pages/about,Shipping Policy|/pages/shipping-policy,Return & Refund Policy|/pages/return-refund-policy,Privacy Policy|/pages/privacy-policy,Terms of Service|/pages/terms-of-service' | split: ','
-%}

<footer class="typsh-shell-footer">
  <div class="typsh-shell-footer__inner page-width">
    <div class="typsh-shell-footer__grid">
      <div class="typsh-shell-footer__brand">
        <a href="{{ routes.root_url }}" class="typsh-shell-footer__brandmark" aria-label="{{ shop.name | escape }}">
          {% render 'typsh-brand-logo', animated: section.settings.use_animated_logo, width: section.settings.logo_width, alt: shop.name %}
        </a>
        <p class="typsh-shell-footer__eyebrow">Useful Finds That Actually Make Life Easier</p>
        <p class="typsh-shell-footer__copy">
          Practical home and tech products, curated for cleaner merchandising, faster decisions, and lower-friction support.
        </p>
        <p class="typsh-shell-footer__copy">
          Free US shipping is built into pricing. Support: <a class="typsh-shell-footer__meta-link" href="mailto:support@typsh.it">support@typsh.it</a>
        </p>
      </div>

      <div class="typsh-shell-footer__columns">
        <div class="typsh-shell-footer__column">
          <h2 class="typsh-shell-footer__label">Shop</h2>
          <ul class="typsh-shell-footer__link-list" role="list">
            {% for item in shop_links %}
              {% assign item_parts = item | split: '|' %}
              <li><a class="typsh-shell-footer__link" href="{{ item_parts[1] }}">{{ item_parts[0] }}</a></li>
            {% endfor %}
          </ul>
        </div>

        <div class="typsh-shell-footer__column">
          <h2 class="typsh-shell-footer__label">Help</h2>
          <ul class="typsh-shell-footer__link-list" role="list">
            {% for item in help_links %}
              {% assign item_parts = item | split: '|' %}
              <li><a class="typsh-shell-footer__link" href="{{ item_parts[1] }}">{{ item_parts[0] }}</a></li>
            {% endfor %}
          </ul>
        </div>

        <div class="typsh-shell-footer__column">
          <h2 class="typsh-shell-footer__label">Legal</h2>
          <ul class="typsh-shell-footer__link-list" role="list">
            {% for item in legal_links %}
              {% assign item_parts = item | split: '|' %}
              <li><a class="typsh-shell-footer__link" href="{{ item_parts[1] }}">{{ item_parts[0] }}</a></li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>

    <div class="typsh-shell-footer__bottom">
      <p class="typsh-shell-footer__meta">© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <p class="typsh-shell-footer__meta">
        <a class="typsh-shell-footer__meta-link" href="/pages/privacy-policy">Privacy policy</a>
      </p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "typsh Footer",
  "settings": [
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 120,
      "max": 280,
      "step": 10,
      "unit": "px",
      "default": 220
    },
    {
      "type": "checkbox",
      "id": "use_animated_logo",
      "label": "Use animated logo",
      "default": false
    }
  ]
}
{% endschema %}