{{ 'typsh-homepage.css' | asset_url | stylesheet_tag }}

<section class="typsh-section typsh-email-capture">
  <div class="typsh-shell">
    <div class="typsh-panel typsh-email-panel">
      <div>
        <p class="typsh-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="typsh-heading">{{ section.settings.heading }}</h2>
        <p class="typsh-lead">{{ section.settings.body }}</p>
      </div>

      <div>
        {% form 'customer', class: 'typsh-email-fields' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="typsh-field-row">
            <input
              id="NewsletterForm-{{ section.id }}"
              type="email"
              name="contact[email]"
              value="{{ form.email }}"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              placeholder="{{ section.settings.placeholder }}"
              required
            >
            <button class="typsh-button typsh-button--primary" type="submit">{{ section.settings.button_label }}</button>
          </div>

          {% if form.errors %}
            <small class="typsh-form-message typsh-form-message--error">{{ form.errors | default_errors }}</small>
          {% elsif form.posted_successfully? %}
            <small class="typsh-form-message typsh-form-message--success">{{ section.settings.success_message }}</small>
          {% endif %}

          <p class="typsh-form-copy">{{ section.settings.disclaimer }}</p>
          <p class="typsh-form-note">{{ section.settings.note }}</p>
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "typsh Email capture",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Capture demand"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get 10% off your first order"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Use this as the lightweight launch signup form until Klaviyo or Shopify Forms takes over the popup and lifecycle flows."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Unlock 10% Off"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks. Your launch offer is on the way."
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "Keep the form light: collect email first, then test SMS as a second step once the store is stable."
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Secondary note",
      "default": "Best replaced later by a Klaviyo embed or Shopify Forms block tied to the welcome flow."
    }
  ],
  "presets": [
    {
      "name": "typsh Email capture"
    }
  ]
}
{% endschema %}