{% liquid
  assign products_to_show = section.settings.products_to_show | default: 4
  assign rendered = 0
  assign manual_handles = section.settings.product_handles | newline_to_br | split: '<br />'
  assign primary_collection = blank
  if product != blank and product.collections != blank and product.collections.size > 0
    assign primary_collection = product.collections.first
  endif
%}

<section class="typsh-commerce-section typsh-recommendations-section">
  <div class="typsh-commerce-shell">
    <div class="typsh-commerce-panel typsh-commerce-recommendations">
      <div class="typsh-commerce-recommendations__header">
        <p class="typsh-commerce-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="typsh-commerce-heading">{{ section.settings.heading }}</h2>
        <p class="typsh-commerce-copy">{{ section.settings.body }}</p>
      </div>

      <div class="typsh-commerce-products">
        {% if primary_collection != blank %}
          {% for related_product in primary_collection.products %}
            {% if related_product.handle != product.handle %}
              {% render 'typsh-commerce-card', product_object: related_product, badge: section.settings.related_badge, quick_add_label: 'Quick add', cta_label: 'View product' %}
              {% assign rendered = rendered | plus: 1 %}
            {% endif %}
            {% if rendered >= products_to_show %}
              {% break %}
            {% endif %}
          {% endfor %}
        {% endif %}

        {% if rendered < products_to_show %}
          {% for handle in manual_handles %}
            {% assign trimmed_handle = handle | strip %}
            {% if trimmed_handle != blank %}
              {% assign manual_product = all_products[trimmed_handle] %}
              {% if manual_product != blank and manual_product.handle != product.handle %}
                {% render 'typsh-commerce-card', product_object: manual_product, badge: section.settings.manual_badge, quick_add_label: 'Quick add', cta_label: 'View product' %}
                {% assign rendered = rendered | plus: 1 %}
              {% endif %}
            {% endif %}
            {% if rendered >= products_to_show %}
              {% break %}
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>

      {% if section.settings.enable_recently_viewed %}
        <div class="typsh-commerce-grid" style="gap: 16px; margin-top: 24px;">
          <div class="typsh-commerce-recommendations__header" style="margin-bottom: 0;">
            <p class="typsh-commerce-eyebrow">Return visits</p>
            <h3 class="typsh-commerce-card__title">Recently viewed</h3>
          </div>
          <div class="typsh-commerce-products" data-typsh-recently-viewed data-current-handle="{{ product.handle }}" hidden></div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "typsh Recommendations",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Intent-based merchandising"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Keep the shopper moving"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Use context-aware pairings and recently viewed memory so the product page behaves more like a guided funnel than a dead end."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "related_badge",
      "label": "Related badge",
      "default": "You may also like"
    },
    {
      "type": "text",
      "id": "manual_badge",
      "label": "Manual fallback badge",
      "default": "Staff pick"
    },
    {
      "type": "textarea",
      "id": "product_handles",
      "label": "Fallback product handles",
      "info": "One handle per line"
    },
    {
      "type": "checkbox",
      "id": "enable_recently_viewed",
      "label": "Enable recently viewed",
      "default": true
    }
  ]
}
{% endschema %}