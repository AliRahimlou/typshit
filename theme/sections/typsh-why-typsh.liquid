{{ 'typsh-homepage.css' | asset_url | stylesheet_tag }}

<section class="typsh-section typsh-why-typsh">
  <div class="typsh-shell">
    <div class="typsh-section-header">
      <p class="typsh-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="typsh-heading">{{ section.settings.heading }}</h2>
      <p class="typsh-lead">{{ section.settings.body }}</p>
    </div>

    <div class="typsh-why-grid">
      <article class="typsh-card typsh-why-step">
        <span class="typsh-step-number">01</span>
        <p class="typsh-card-copy">{{ section.settings.point_one }}</p>
      </article>

      <article class="typsh-card typsh-why-step">
        <span class="typsh-step-number">02</span>
        <p class="typsh-card-copy">{{ section.settings.point_two }}</p>
      </article>

      <article class="typsh-card typsh-why-step">
        <span class="typsh-step-number">03</span>
        <p class="typsh-card-copy">{{ section.settings.point_three }}</p>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "typsh Why typsh",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Brand filter"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why typsh.it"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "This section should answer the quiet question every shopper has: why should I trust this store over a random gadget catalog?"
    },
    {
      "type": "textarea",
      "id": "point_one",
      "label": "Point 1",
      "default": "We do not sell endless random gadgets just to pad the catalog."
    },
    {
      "type": "textarea",
      "id": "point_two",
      "label": "Point 2",
      "default": "Every product is selected because the problem and payoff are easy to understand."
    },
    {
      "type": "textarea",
      "id": "point_three",
      "label": "Point 3",
      "default": "The store favors clean answers, usable product pages, and lower-friction support."
    }
  ],
  "presets": [
    {
      "name": "typsh Why typsh"
    }
  ]
}
{% endschema %}