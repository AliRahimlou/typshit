{% liquid
  assign featured_product = blank
  if section.settings.featured_product != blank
    assign featured_product = section.settings.featured_product
    if featured_product.url == blank
      assign featured_product = all_products[section.settings.featured_product]
    endif
  endif

  assign visual_image = section.settings.image
  if visual_image == blank and featured_product != blank and featured_product.featured_media != blank
    assign visual_image = featured_product.featured_media.preview_image
  endif
%}

<section class="typsh-commerce-section typsh-prelander-section">
  <div class="typsh-commerce-shell">
    <div class="typsh-commerce-panel typsh-commerce-prelander__panel">
      <div class="typsh-commerce-prelander__layout">
        <div class="typsh-commerce-grid" style="gap: 18px;">
          <p class="typsh-commerce-eyebrow">{{ section.settings.eyebrow }}</p>
          <h1 class="typsh-commerce-title">{{ section.settings.heading }}</h1>
          <p class="typsh-commerce-prelander__copy">{{ section.settings.body }}</p>
          <div class="typsh-commerce-actions typsh-commerce-prelander__cta">
            <a class="typsh-commerce-button typsh-commerce-button--primary" href="{{ section.settings.primary_url }}">{{ section.settings.primary_label }}</a>
            <a class="typsh-commerce-link-button" href="{{ section.settings.secondary_url }}">{{ section.settings.secondary_label }}</a>
          </div>
        </div>

        <div class="typsh-commerce-grid" style="gap: 18px;">
          <div class="typsh-commerce-prelander__media">
            {% if visual_image != blank %}
              {{ visual_image | image_url: width: 1200 | image_tag: widths: '480, 720, 960, 1200', sizes: '(min-width: 990px) 42vw, 100vw', loading: 'lazy', alt: section.settings.heading }}
            {% else %}
              <div class="typsh-commerce-empty" style="display:grid;place-items:center;height:100%;min-height:420px;">Pre-lander visual</div>
            {% endif %}
          </div>

          {% if featured_product != blank %}
            {% render 'typsh-commerce-card', product_object: featured_product, badge: section.settings.product_badge, quick_add_label: 'Quick add', cta_label: 'View product' %}
          {% endif %}
        </div>
      </div>

      <div class="typsh-commerce-prelander__proof" style="margin-top: 22px;">
        {% for block in section.blocks %}
          <article class="typsh-commerce-prelander__proof-card" {{ block.shopify_attributes }}>
            <p class="typsh-commerce-kicker">{{ block.settings.stat }}</p>
            <h2 class="typsh-commerce-card__title">{{ block.settings.title }}</h2>
            <p class="typsh-commerce-copy">{{ block.settings.copy }}</p>
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "typsh Pre-lander",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Paid social pre-sell"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Bridge ad traffic into a clearer buying context"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Use this template when traffic needs one more layer of context before hitting the PDP. The design should still feel fast, thumb-friendly, and visually native to the main theme."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary label",
      "default": "Shop the featured product"
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "Primary URL"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary label",
      "default": "See customer questions"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary URL"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Visual override"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured product"
    },
    {
      "type": "text",
      "id": "product_badge",
      "label": "Featured product badge",
      "default": "Featured offer"
    }
  ],
  "blocks": [
    {
      "type": "proof",
      "name": "Proof card",
      "settings": [
        {
          "type": "text",
          "id": "stat",
          "label": "Stat or label",
          "default": "Why it converts"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Clarify the use case fast"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "Pre-landers work best when they remove one layer of confusion, not when they become a long-form distraction page."
        }
      ]
    }
  ]
}
{% endschema %}