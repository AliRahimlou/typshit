{{ 'typsh-homepage.css' | asset_url | stylesheet_tag }}

<section class="typsh-section typsh-featured-products">
  <div class="typsh-shell">
    <div class="typsh-section-header">
      <p class="typsh-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="typsh-heading">{{ section.settings.heading }}</h2>
      <p class="typsh-lead">{{ section.settings.body }}</p>
    </div>

    <div class="typsh-product-grid">
      {% render 'typsh-product-card', product_handle: section.settings.product_one_handle, badge: section.settings.product_one_badge, summary: section.settings.product_one_summary, cta_label: section.settings.product_one_cta %}
      {% render 'typsh-product-card', product_handle: section.settings.product_two_handle, badge: section.settings.product_two_badge, summary: section.settings.product_two_summary, cta_label: section.settings.product_two_cta %}
      {% render 'typsh-product-card', product_handle: section.settings.product_three_handle, badge: section.settings.product_three_badge, summary: section.settings.product_three_summary, cta_label: section.settings.product_three_cta %}
      {% render 'typsh-product-card', product_handle: section.settings.product_four_handle, badge: section.settings.product_four_badge, summary: section.settings.product_four_summary, cta_label: section.settings.product_four_cta %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "typsh Featured products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Above the fold"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Keep the first scan tight: four products, clear problem-solver positioning, and real synced imagery instead of a crowded all-products wall."
    },
    {
      "type": "text",
      "id": "product_one_handle",
      "label": "Product 1 handle",
      "default": "handheld-clothes-steamer"
    },
    {
      "type": "text",
      "id": "product_one_badge",
      "label": "Product 1 badge",
      "default": "Save $20"
    },
    {
      "type": "textarea",
      "id": "product_one_summary",
      "label": "Product 1 summary",
      "default": "Wrinkle-free outfits in minutes without dragging out a full ironing board."
    },
    {
      "type": "text",
      "id": "product_one_cta",
      "label": "Product 1 CTA",
      "default": "Shop now"
    },
    {
      "type": "text",
      "id": "product_two_handle",
      "label": "Product 2 handle",
      "default": "magnetic-screen-door"
    },
    {
      "type": "text",
      "id": "product_two_badge",
      "label": "Product 2 badge",
      "default": "Problem solver"
    },
    {
      "type": "textarea",
      "id": "product_two_summary",
      "label": "Product 2 summary",
      "default": "Let fresh air in and keep bugs out without tools or permanent hassle."
    },
    {
      "type": "text",
      "id": "product_two_cta",
      "label": "Product 2 CTA",
      "default": "Shop now"
    },
    {
      "type": "text",
      "id": "product_three_handle",
      "label": "Product 3 handle",
      "default": "wireless-charging-station"
    },
    {
      "type": "text",
      "id": "product_three_badge",
      "label": "Product 3 badge",
      "default": "Desk upgrade"
    },
    {
      "type": "textarea",
      "id": "product_three_summary",
      "label": "Product 3 summary",
      "default": "One compact charging hub for cleaner desks, nightstands, and shared spaces."
    },
    {
      "type": "text",
      "id": "product_three_cta",
      "label": "Product 3 CTA",
      "default": "Shop now"
    },
    {
      "type": "text",
      "id": "product_four_handle",
      "label": "Product 4 handle",
      "default": "ring-light"
    },
    {
      "type": "text",
      "id": "product_four_badge",
      "label": "Product 4 badge",
      "default": "Creator pick"
    },
    {
      "type": "textarea",
      "id": "product_four_summary",
      "label": "Product 4 summary",
      "default": "Better lighting for content, calls, and everyday desk setups without bulky gear."
    },
    {
      "type": "text",
      "id": "product_four_cta",
      "label": "Product 4 CTA",
      "default": "Shop now"
    }
  ],
  "presets": [
    {
      "name": "typsh Featured products"
    }
  ]
}
{% endschema %}