{{ 'typsh-homepage.css' | asset_url | stylesheet_tag }}

<section class="typsh-section typsh-faq-preview">
  <div class="typsh-shell">
    <div class="typsh-section-header">
      <p class="typsh-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="typsh-heading">{{ section.settings.heading }}</h2>
      <p class="typsh-lead">{{ section.settings.body }}</p>
    </div>

    <div class="typsh-faq-list">
      <details class="typsh-faq-item" open>
        <summary>
          <h3 class="typsh-faq-question">{{ section.settings.question_one }}</h3>
          <span class="typsh-faq-toggle">+</span>
        </summary>
        <p class="typsh-faq-answer">{{ section.settings.answer_one }}</p>
      </details>

      <details class="typsh-faq-item">
        <summary>
          <h3 class="typsh-faq-question">{{ section.settings.question_two }}</h3>
          <span class="typsh-faq-toggle">+</span>
        </summary>
        <p class="typsh-faq-answer">{{ section.settings.answer_two }}</p>
      </details>

      <details class="typsh-faq-item">
        <summary>
          <h3 class="typsh-faq-question">{{ section.settings.question_three }}</h3>
          <span class="typsh-faq-toggle">+</span>
        </summary>
        <p class="typsh-faq-answer">{{ section.settings.answer_three }}</p>
      </details>
    </div>

    <div class="typsh-button-row">
      <a class="typsh-button typsh-button--secondary" href="{{ section.settings.faq_page_url }}">{{ section.settings.faq_page_label }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "typsh FAQ preview",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Answer first"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Common launch questions"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Keep the homepage FAQ short, direct, and operational. This is trust-building copy, not filler."
    },
    {
      "type": "text",
      "id": "question_one",
      "label": "Question 1",
      "default": "What kind of products does typsh.it carry?"
    },
    {
      "type": "textarea",
      "id": "answer_one",
      "label": "Answer 1",
      "default": "typsh.it focuses on practical home and tech finds that solve real everyday problems without feeling cluttered or gimmicky."
    },
    {
      "type": "text",
      "id": "question_two",
      "label": "Question 2",
      "default": "Where do you ship?"
    },
    {
      "type": "textarea",
      "id": "answer_two",
      "label": "Answer 2",
      "default": "The launch store is focused on the United States, with free US shipping built into product pricing."
    },
    {
      "type": "text",
      "id": "question_three",
      "label": "Question 3",
      "default": "How do returns and support work?"
    },
    {
      "type": "textarea",
      "id": "answer_three",
      "label": "Answer 3",
      "default": "If an order arrives damaged or defective, customers can contact support@typsh.it within 30 days for help."
    },
    {
      "type": "text",
      "id": "faq_page_label",
      "label": "FAQ page CTA label",
      "default": "Read full FAQ"
    },
    {
      "type": "url",
      "id": "faq_page_url",
      "label": "FAQ page URL"
    }
  ],
  "presets": [
    {
      "name": "typsh FAQ preview"
    }
  ]
}
{% endschema %}