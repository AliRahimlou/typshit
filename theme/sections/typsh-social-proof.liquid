{{ 'typsh-homepage.css' | asset_url | stylesheet_tag }}

<section class="typsh-section typsh-social-proof">
  <div class="typsh-shell">
    <div class="typsh-section-header">
      <p class="typsh-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="typsh-heading">{{ section.settings.heading }}</h2>
      <p class="typsh-lead">{{ section.settings.body }}</p>
    </div>

    <div class="typsh-proof-grid">
      <article class="typsh-card">
        <p class="typsh-proof-quote">{{ section.settings.quote_one }}</p>
        <div class="typsh-proof-meta">
          <span class="typsh-proof-author">{{ section.settings.author_one }}</span>
          <p class="typsh-quote-context">{{ section.settings.context_one }}</p>
        </div>
      </article>

      <article class="typsh-card">
        <p class="typsh-proof-quote">{{ section.settings.quote_two }}</p>
        <div class="typsh-proof-meta">
          <span class="typsh-proof-author">{{ section.settings.author_two }}</span>
          <p class="typsh-quote-context">{{ section.settings.context_two }}</p>
        </div>
      </article>

      <article class="typsh-card">
        <p class="typsh-proof-quote">{{ section.settings.quote_three }}</p>
        <div class="typsh-proof-meta">
          <span class="typsh-proof-author">{{ section.settings.author_three }}</span>
          <p class="typsh-quote-context">{{ section.settings.context_three }}</p>
        </div>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "typsh Social proof",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Text-led proof"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Early trust signals"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Use these as concise trust cards that sound like real customer sentiment, not internal notes about a future reviews app."
    },
    {
      "type": "textarea",
      "id": "quote_one",
      "label": "Quote 1",
      "default": "The store feels curated. I found what I needed fast and the product explained the benefit immediately."
    },
    {
      "type": "text",
      "id": "author_one",
      "label": "Author 1",
      "default": "Early home-fixes customer"
    },
    {
      "type": "text",
      "id": "context_one",
      "label": "Context 1",
      "default": "Strong fit for the first trust row right after featured products."
    },
    {
      "type": "textarea",
      "id": "quote_two",
      "label": "Quote 2",
      "default": "The desk setup products feel cleaner and more premium than the usual impulse-buy gadget stores."
    },
    {
      "type": "text",
      "id": "author_two",
      "label": "Author 2",
      "default": "Desk setup buyer"
    },
    {
      "type": "text",
      "id": "context_two",
      "label": "Context 2",
      "default": "Useful for reinforcing creator and tech-oriented products without adding clutter."
    },
    {
      "type": "textarea",
      "id": "quote_three",
      "label": "Quote 3",
      "default": "Shipping and support details were easy to find, which made the purchase feel lower risk."
    },
    {
      "type": "text",
      "id": "author_three",
      "label": "Author 3",
      "default": "Support-conscious shopper"
    },
    {
      "type": "text",
      "id": "context_three",
      "label": "Context 3",
      "default": "Best placed near FAQ and policy confidence cues."
    }
  ],
  "presets": [
    {
      "name": "typsh Social proof"
    }
  ]
}
{% endschema %}