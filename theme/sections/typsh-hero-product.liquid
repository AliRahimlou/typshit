{% liquid
  assign hero_product = all_products[section.settings.product_handle]
  assign hero_image = section.settings.image
  if hero_image == blank and hero_product != blank and hero_product.featured_media != blank
    assign hero_image = hero_product.featured_media.preview_image
  endif
%}

{{ 'typsh-homepage.css' | asset_url | stylesheet_tag }}

<section class="typsh-section typsh-hero-product">
  <div class="typsh-shell">
    <div class="typsh-panel typsh-hero-product__panel">
      <div>
        <p class="typsh-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="typsh-heading">{{ section.settings.heading }}</h2>
        <p class="typsh-lead">{{ section.settings.body }}</p>

        <ul class="typsh-list" role="list">
          {% if section.settings.bullet_one != blank %}
            <li>{{ section.settings.bullet_one }}</li>
          {% endif %}
          {% if section.settings.bullet_two != blank %}
            <li>{{ section.settings.bullet_two }}</li>
          {% endif %}
          {% if section.settings.bullet_three != blank %}
            <li>{{ section.settings.bullet_three }}</li>
          {% endif %}
        </ul>

        <div class="typsh-button-row">
          <a class="typsh-button typsh-button--primary" href="{{ section.settings.primary_cta_url }}">{{ section.settings.primary_cta_label }}</a>
          <a class="typsh-button typsh-button--secondary" href="{{ section.settings.secondary_cta_url }}">{{ section.settings.secondary_cta_label }}</a>
        </div>
      </div>

      <div>
        <div class="typsh-media-frame typsh-media-frame--portrait">
          {% if hero_image != blank %}
            {{ hero_image | image_url: width: 1200 | image_tag: widths: '480, 720, 960, 1200', sizes: '(min-width: 990px) 42vw, 100vw', loading: 'lazy', alt: section.settings.heading }}
          {% else %}
            <div class="typsh-placeholder">Hero product</div>
          {% endif %}
        </div>
        {% if hero_product != blank %}
          <div class="typsh-card" style="margin-top: 18px;">
            <p class="typsh-caption">Current hero product</p>
            <h3 class="typsh-card-title">{{ hero_product.title }}</h3>
            <p class="typsh-card-copy">{{ hero_product.description | strip_html | truncatewords: 24 }}</p>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "typsh Hero product",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Merchandising anchor"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our hero product: the fast way to look put together"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Feature the Handheld Clothes Steamer as the main merchandising anchor. The use case is obvious, the demo value is high, and the benefit is understood in seconds."
    },
    {
      "type": "text",
      "id": "product_handle",
      "label": "Product handle",
      "default": "handheld-clothes-steamer"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image override"
    },
    {
      "type": "text",
      "id": "bullet_one",
      "label": "Bullet 1",
      "default": "Smooths wrinkles quickly without pulling out a full ironing board."
    },
    {
      "type": "text",
      "id": "bullet_two",
      "label": "Bullet 2",
      "default": "Compact handheld format for fast touch-ups before work, travel, or events."
    },
    {
      "type": "text",
      "id": "bullet_three",
      "label": "Bullet 3",
      "default": "Simple water-fill design with a lightweight body for everyday use."
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Primary CTA label",
      "default": "Shop the Steamer"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "Primary CTA URL"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary CTA label",
      "default": "View Home Refresh Bundle"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Secondary CTA URL"
    }
  ],
  "presets": [
    {
      "name": "typsh Hero product"
    }
  ]
}
{% endschema %}