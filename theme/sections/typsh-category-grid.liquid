{{ 'typsh-homepage.css' | asset_url | stylesheet_tag }}

<section class="typsh-section typsh-category-grid-section">
  <div class="typsh-shell">
    <div class="typsh-section-header">
      <p class="typsh-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="typsh-heading">{{ section.settings.heading }}</h2>
      <p class="typsh-lead">{{ section.settings.body }}</p>
    </div>

    <div class="typsh-category-grid">
      {% render 'typsh-category-card', collection_handle: section.settings.collection_one_handle, href: section.settings.collection_one_url, title: section.settings.collection_one_title, summary: section.settings.collection_one_summary %}
      {% render 'typsh-category-card', collection_handle: section.settings.collection_two_handle, href: section.settings.collection_two_url, title: section.settings.collection_two_title, summary: section.settings.collection_two_summary %}
      {% render 'typsh-category-card', collection_handle: section.settings.collection_three_handle, href: section.settings.collection_three_url, title: section.settings.collection_three_title, summary: section.settings.collection_three_summary %}
      {% render 'typsh-category-card', collection_handle: section.settings.collection_four_handle, href: section.settings.collection_four_url, title: section.settings.collection_four_title, summary: section.settings.collection_four_summary %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "typsh Category grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Merchandising lanes"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by category"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Use collections as purposeful shopping lanes instead of an endless filter wall. Each card should feel like a clear next step for the visitor."
    },
    {
      "type": "text",
      "id": "collection_one_handle",
      "label": "Collection 1 handle",
      "default": "home-fixes"
    },
    {
      "type": "text",
      "id": "collection_one_title",
      "label": "Collection 1 title",
      "default": "Home Fixes"
    },
    {
      "type": "textarea",
      "id": "collection_one_summary",
      "label": "Collection 1 summary",
      "default": "Low-friction upgrades for wrinkles, airflow, and everyday cleanup annoyances."
    },
    {
      "type": "url",
      "id": "collection_one_url",
      "label": "Collection 1 URL"
    },
    {
      "type": "text",
      "id": "collection_two_handle",
      "label": "Collection 2 handle",
      "default": "tech-essentials"
    },
    {
      "type": "text",
      "id": "collection_two_title",
      "label": "Collection 2 title",
      "default": "Tech Essentials"
    },
    {
      "type": "textarea",
      "id": "collection_two_summary",
      "label": "Collection 2 summary",
      "default": "Clean desk and charging products that make daily routines feel less messy."
    },
    {
      "type": "url",
      "id": "collection_two_url",
      "label": "Collection 2 URL"
    },
    {
      "type": "text",
      "id": "collection_three_handle",
      "label": "Collection 3 handle",
      "default": "creator-setup"
    },
    {
      "type": "text",
      "id": "collection_three_title",
      "label": "Collection 3 title",
      "default": "Creator Setup"
    },
    {
      "type": "textarea",
      "id": "collection_three_summary",
      "label": "Collection 3 summary",
      "default": "Straightforward gear for better lighting, cleaner setups, and faster content capture."
    },
    {
      "type": "url",
      "id": "collection_three_url",
      "label": "Collection 3 URL"
    },
    {
      "type": "text",
      "id": "collection_four_handle",
      "label": "Collection 4 handle",
      "default": "problem-solvers"
    },
    {
      "type": "text",
      "id": "collection_four_title",
      "label": "Collection 4 title",
      "default": "Problem Solvers"
    },
    {
      "type": "textarea",
      "id": "collection_four_summary",
      "label": "Collection 4 summary",
      "default": "The full launch assortment of practical products selected to solve real frustrations quickly."
    },
    {
      "type": "url",
      "id": "collection_four_url",
      "label": "Collection 4 URL"
    }
  ],
  "presets": [
    {
      "name": "typsh Category grid"
    }
  ]
}
{% endschema %}